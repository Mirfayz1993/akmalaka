# Database
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/wood_erp

# NextAuth — obligatory for production
# Generate with: openssl rand -base64 32
AUTH_SECRET=your-secret-key-min-32-chars

# Admin credentials
ADMIN_USERNAME=admin
# Generate password hash: node scripts/hash-password.js YOUR_PASSWORD
ADMIN_PASSWORD_HASH=$2b$10$...bcrypt_hash_here...
